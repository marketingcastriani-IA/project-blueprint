<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <AssemblyName>ProfitRTDBridge</AssemblyName>
    <RootNamespace>ProfitRTDBridge</RootNamespace>
    <Nullable>enable</Nullable>
    <UseWindowsForms>false</UseWindowsForms>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <ApplicationIcon />
    <AssemblyTitle>ProfitRTD Bridge</AssemblyTitle>
    <Company>OpçõesPROX</Company>
    <Product>ProfitRTD Bridge</Product>
    <Description>Bridge entre o RTD do Profit Pro (Nelogica) e apps web via WebSocket</Description>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <!-- WebSocket server leve -->
    <PackageReference Include="Fleck" Version="1.2.0" />
    <!-- JSON serialization -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <!-- COM Reference para Excel Interop -->
  <ItemGroup>
    <COMReference Include="Microsoft.Office.Interop.Excel">
      <Guid>{00020813-0000-0000-C000-000000000046}</Guid>
      <VersionMajor>1</VersionMajor>
      <VersionMinor>9</VersionMinor>
      <Lcid>0</Lcid>
      <WrapperTool>tlbimp</WrapperTool>
      <Isolated>false</Isolated>
      <EmbedInteropTypes>true</EmbedInteropTypes>
    </COMReference>
  </ItemGroup>

</Project>
